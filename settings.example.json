{
  "llmProvider": "openai",
  "openaiApiKey": "sk-your-key-here",
  "modelRouting": {
    "gpt-5-mini": "azure"
  },
  "port": 3000,
  "newsProvider": "google",
  "newsApiKey": "",
  "mcp": {
    "approvalMode": "off"
  },
  "foundry": {
    "enabled": false,
    "projectEndpoint": "https://your-foundry-resource.services.ai.azure.com/api/projects/proj-default",
    "authMode": "entra",
    "bearerToken": "",
    "tenantId": "",
    "clientId": "",
    "clientSecret": "",
    "apiVersion": "2025-11-15-preview",
    "routerApplicationName": "model-router",
    "routerApplicationVersion": "2"
  },
  "toolPolicy": {
    "timeoutMs": 45000,
    "fileAllowlist": []
  },
  "_examples": {
    "openaiMinimal": {
      "llmProvider": "openai",
      "openaiApiKey": "sk-your-key-here"
    },
    "azureRecommended": {
      "llmProvider": "azure",
      "azureInference": {
        "apiKey": "",
        "endpoint": "https://your-resource.openai.azure.com",
        "apiVersion": "2024-10-21",
        "defaultDeployment": "gpt-5-mini",
        "deployments": {
          "gpt-5-mini": "gpt-5-mini",
          "gpt-5.2": "gpt-5.2",
          "gpt-4.1": "gpt-4.1",
          "gpt-4o": "gpt-4o",
          "gpt-4o-mini": "gpt-4o-mini",
          "claude-sonnet": "claude-sonnet"
        }
      }
    },
    "hybridRouting": {
      "llmProvider": "openai",
      "openaiApiKey": "sk-your-key-here",
      "modelRouting": {
        "gpt-5-mini": "azure"
      },
      "azureInference": {
        "apiKey": "",
        "endpoint": "https://your-resource.openai.azure.com",
        "apiVersion": "2024-10-21",
        "defaultDeployment": "gpt-5-mini",
        "deployments": {
          "gpt-5-mini": "gpt-5-mini"
        }
      }
    },
    "foundryDirectApplication": {
      "foundry": {
        "enabled": true,
        "projectEndpoint": "https://your-foundry-resource.services.ai.azure.com/api/projects/proj-default",
        "authMode": "entra",
        "bearerToken": "",
        "tenantId": "your-tenant-id",
        "clientId": "your-client-id",
        "clientSecret": "your-client-secret",
        "apiVersion": "2025-11-15-preview",
        "routerApplicationName": "model-router"
      }
    }
  },
  "_notes": {
    "foundryApplications": "Manage Foundry application targets in data/settings/foundry-applications.json (the admin UI writes to that file) instead of embedding them in settings.local.json."
  }
}
